# ─── APPLICATION ────────────────────────────────────────────────────────────
ENVIRONMENT=development                    # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ─── SECURITY ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-256-bit-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# ─── DATABASE ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=Pytomatiza
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:change-this-to-a-strong-password@localhost:5432/Pytomatiza
DB_ECHO=false   

# ─── REDIS ──────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-to-a-strong-password
REDIS_URL=redis://:change-this-to-a-strong-password@redis:6379/0

# ─── GOOGLE OAUTH ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── GOOGLE API SCOPES ──────────────────────────────────────────────────────
# Scopes requested for Google Drive integration (readonly access to files)
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly
# Scopes requested for Google Photos integration (readonly access to library)
GOOGLE_PHOTOS_SCOPES=https://www.googleapis.com/auth/photoslibrary.readonly
# Base OIDC scopes for authentication (do not change)
GOOGLE_OIDC_SCOPES=openid email profile

# ─── RESEND (email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Pytomatiza+ <noreply@yourdomain.com>

# ─── FRONTEND ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# ─── MONITORING — SENTRY ────────────────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn

# ─── MONITORING — PROMETHEUS / GRAFANA ──────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ─── RATE LIMITING ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ─── AI AGENTS ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
CREWAI_MODEL=llama3
LANGCHAIN_TRACING_V2=false

# ─── AWS S3 & Lambda Configuration for Document Processing ──────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
LAMBDA_FUNCTION_NAME=your-lambda-function-name
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:your-topic-name

# ─── Upload Limits ─────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
# Allowed file extensions (comma-separated)
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tiff,.bmp,.doc,.docx,.txt,.csv,.xlsx